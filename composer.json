{
    "name": "respect/validation-bundle",
    "type": "symfony-bundle",
    "description": "Symfony bundle for Respect\\Validation",
    "keywords": [
        "respect",
        "validation",
        "symfony",
        "bundle"
    ],
    "homepage": "https://github.com/Respect/ValidationBundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Respect/Validation Contributors",
            "homepage": "https://github.com/Respect/ValidationBundle/graphs/contributors"
        }
    ],
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        }
    },
    "require": {
        "php": ">=8.5",
        "psr/container": "^2.0",
        "respect/validation": "^3.0",
        "symfony/config": "^8.0",
        "symfony/dependency-injection": "^8.0",
        "symfony/http-kernel": "^8.0"
    },
    "require-dev": {
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^13.2",
        "respect/coding-standard": "^5.0",
        "squizlabs/php_codesniffer": "^4.0",
        "symfony/framework-bundle": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "Respect\\ValidationBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Respect\\ValidationBundle\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpcs": "vendor/bin/phpcs",
        "phpstan": "vendor/bin/phpstan analyze",
        "phpunit": "vendor/bin/phpunit",
        "qa": [
            "@phpcs",
            "@phpstan",
            "@phpunit"
        ]
    }
}
